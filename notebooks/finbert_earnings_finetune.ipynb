   "source": [
    "# FinBERT Earnings Signal Fine-Tuner\n",
    "**Pipeline:** Alpha Vantage transcripts → price-based labels → FinBERT fine-tune → evaluation\n",
    "\n",
    "### Before running:\n",
    "1. Go to **Runtime → Change runtime type → T4 GPU**\n",
    "2. Paste your Alpha Vantage API key in the cell below\n",
    "3. Run all cells top to bottom (`Runtime → Run all`)"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── 0. CONFIG ─────────────────────────────────────────────────────────────────\n",
    "API_KEY = \"74TBXZO1PQNBIN7P\"   # Your Alpha Vantage key\n",
    "\n",
    "# Tickers to pull transcripts for (add/remove as you like)\n",
    "TICKERS = [\n",
    "    \"AAPL\", \"MSFT\", \"NVDA\", \"GOOGL\", \"META\",\n",
    "    \"AMZN\", \"TSLA\", \"JPM\", \"BAC\", \"GS\",\n",
    "    \"LLY\", \"JNJ\", \"UNH\", \"XOM\", \"CVX\",\n",
    "    \"HD\", \"WMT\", \"MCD\", \"NKE\", \"CRM\"\n",
    "]\n",
    "\n",
    "# Labeling thresholds (3-day post-earnings return)\n",
    "BUY_THRESHOLD  =  0.03   # +3% or more  → Buy\n",
    "SELL_THRESHOLD = -0.03   # -3% or less  → Sell\n",
    "# Between -3% and +3%    → Hold\n",
    "\n",
    "# Training config\n",
    "MODEL_NAME     = \"ProsusAI/finbert\"\n",
    "MAX_TOKENS     = 512       # FinBERT max; transcripts will be chunked & averaged\n",
    "EPOCHS         = 4\n",
    "BATCH_SIZE     = 8\n",
    "LEARNING_RATE  = 2e-5\n",
    "TEST_SPLIT     = 0.15\n",
    "RANDOM_SEED    = 42\n",
    "\n",
    "LABEL2ID = {\"Buy\": 0, \"Hold\": 1, \"Sell\": 2}\n",
    "ID2LABEL = {v: k for k, v in LABEL2ID.items()}"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── 1. INSTALL DEPENDENCIES ───────────────────────────────────────────────────\n",
    "!pip install -q transformers datasets accelerate scikit-learn pandas requests tqdm"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── 2. IMPORTS ────────────────────────────────────────────────────────────────\n",
    "import requests, time, json\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "from datetime import datetime, timedelta\n",
    "from tqdm.auto import tqdm\n",
    "\n",
    "import torch\n",
    "from torch.utils.data import Dataset\n",
    "from transformers import (\n",
    "    AutoTokenizer, AutoModelForSequenceClassification,\n",
    "    TrainingArguments, Trainer\n",
    ")\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.metrics import classification_report, confusion_matrix\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "print(f\"Using device: {device}\")"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── 3. FETCH TRANSCRIPTS FROM ALPHA VANTAGE ───────────────────────────────────\n",
    "# Alpha Vantage returns up to the last 4 quarters per ticker (free tier)\n",
    "\n",
    "def fetch_transcripts(ticker: str) -> list[dict]:\n",
    "    \"\"\"Returns a list of {ticker, date, text} dicts for all available quarters.\"\"\"\n",
    "    url = (\n",
    "        f\"https://www.alphavantage.co/query\"\n",
    "        f\"?function=EARNINGS_CALL_TRANSCRIPT\"\n",
    "        f\"&symbol={ticker}\"\n",
    "        f\"&apikey={API_KEY}\"\n",
    "    )\n",
    "    resp = requests.get(url, timeout=20)\n",
    "    data = resp.json()\n",
    "\n",
    "    results = []\n",
    "    # AV returns a list under 'transcript' key\n",
    "    for item in data.get(\"transcript\", []):\n",
    "        text = item.get(\"content\", \"\")\n",
    "        date = item.get(\"date\", \"\")          # Format: YYYY-MM-DD\n",
    "        quarter = item.get(\"quarter\", \"\")\n",
    "        if text and date:\n",
    "            results.append({\"ticker\": ticker, \"date\": date,\n",
    "                            \"quarter\": quarter, \"text\": text})\n",
    "    return results\n",
    "\n",
    "\n",
    "print(\"Fetching transcripts (respecting 5 req/min free-tier rate limit)...\")\n",
    "all_transcripts = []\n",
    "\n",
    "for i, ticker in enumerate(tqdm(TICKERS)):\n",
    "    try:\n",
    "        results = fetch_transcripts(ticker)\n",
    "        all_transcripts.extend(results)\n",
    "    except Exception as e:\n",
    "        print(f\"  ⚠ {ticker}: {e}\")\n",
    "    # Free tier: 25 req/day, 5/min — wait 13s between calls to stay safe\n",
    "    if i < len(TICKERS) - 1:\n",
    "        time.sleep(13)\n",
    "\n",
    "df_transcripts = pd.DataFrame(all_transcripts)\n",
    "print(f\"\\nFetched {len(df_transcripts)} transcripts across {df_transcripts['ticker'].nunique()} tickers\")\n",
    "df_transcripts.head()"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── 4. FETCH POST-EARNINGS PRICE RETURNS ──────────────────────────────────────\n",
    "# For each transcript date, get the 3-day forward return to auto-label\n",
    "\n",
    "_price_cache = {}  # ticker → DataFrame of daily closes\n",
    "\n",
    "def get_daily_prices(ticker: str) -> pd.DataFrame:\n",
    "    \"\"\"Fetch full daily price history for a ticker (cached).\"\"\"\n",
    "    if ticker in _price_cache:\n",
    "        return _price_cache[ticker]\n",
    "    url = (\n",
    "        f\"https://www.alphavantage.co/query\"\n",
    "        f\"?function=TIME_SERIES_DAILY_ADJUSTED\"\n",
    "        f\"&symbol={ticker}\"\n",
    "        f\"&outputsize=full\"\n",
    "        f\"&apikey={API_KEY}\"\n",
    "    )\n",
    "    resp = requests.get(url, timeout=20)\n",
    "    raw = resp.json().get(\"Time Series (Daily)\", {})\n",
    "    if not raw:\n",
    "        return pd.DataFrame()\n",
    "    df = pd.DataFrame(raw).T\n",
    "    df.index = pd.to_datetime(df.index)\n",
    "    df = df.sort_index()\n",
    "    df[\"close\"] = df[\"5. adjusted close\"].astype(float)\n",
    "    _price_cache[ticker] = df[[\"close\"]]\n",
    "    return df[[\"close\"]]\n",
    "\n",
    "\n",
    "def get_3day_return(ticker: str, earnings_date: str) -> float | None:\n",
    "    \"\"\"Return the 3-trading-day forward return after earnings_date.\"\"\"\n",
    "    prices = get_daily_prices(ticker)\n",
    "    if prices.empty:\n",
    "        return None\n",
    "    date = pd.to_datetime(earnings_date)\n",
    "    # Find the first trading day on or after the earnings date\n",
    "    future = prices[prices.index >= date]\n",
    "    if len(future) < 4:   # need day 0 + 3 forward days\n",
    "        return None\n",
    "    price_day0 = future.iloc[0][\"close\"]\n",
    "    price_day3 = future.iloc[3][\"close\"]\n",
    "    return (price_day3 - price_day0) / price_day0\n",
    "\n",
    "\n",
    "def return_to_label(ret: float) -> str:\n",
    "    if ret >= BUY_THRESHOLD:  return \"Buy\"\n",
    "    if ret <= SELL_THRESHOLD: return \"Sell\"\n",
    "    return \"Hold\"\n",
    "\n",
    "\n",
    "print(\"Fetching price data and generating labels...\")\n",
    "unique_tickers = df_transcripts[\"ticker\"].unique().tolist()\n",
    "\n",
    "for i, ticker in enumerate(tqdm(unique_tickers)):\n",
    "    try:\n",
    "        get_daily_prices(ticker)   # pre-fetch into cache\n",
    "    except Exception as e:\n",
    "        print(f\"  ⚠ {ticker}: {e}\")\n",
    "    if i < len(unique_tickers) - 1:\n",
    "        time.sleep(13)\n",
    "\n",
    "returns, labels = [], []\n",
    "for _, row in df_transcripts.iterrows():\n",
    "    ret = get_3day_return(row[\"ticker\"], row[\"date\"])\n",
    "    returns.append(ret)\n",
    "    labels.append(return_to_label(ret) if ret is not None else None)\n",
    "\n",
    "df_transcripts[\"return_3d\"] = returns\n",
    "df_transcripts[\"label\"]     = labels\n",
    "\n",
    "# Drop rows where we couldn't get price data\n",
    "df_labeled = df_transcripts.dropna(subset=[\"label\", \"text\"]).copy()\n",
    "df_labeled[\"label_id\"] = df_labeled[\"label\"].map(LABEL2ID)\n",
    "\n",
    "print(f\"\\nLabeled dataset: {len(df_labeled)} samples\")\n",
    "print(df_labeled[\"label\"].value_counts())"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── 5. TOKENIZATION & CHUNKING ────────────────────────────────────────────────\n",
    "# Earnings transcripts are long. Strategy:\n",
    "#   Split into 512-token chunks → get logits for each chunk → mean-pool → classify\n",
    "# During training we use the FIRST chunk only (captures CEO opening remarks).\n",
    "# At inference time we mean-pool all chunks for a richer signal.\n",
    "\n",
    "tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)\n",
    "\n",
    "def tokenize_first_chunk(text: str) -> dict:\n",
    "    \"\"\"Tokenize just the first 512 tokens — fast for training.\"\"\"\n",
    "    return tokenizer(\n",
    "        text,\n",
    "        max_length=MAX_TOKENS,\n",
    "        truncation=True,\n",
    "        padding=\"max_length\",\n",
    "        return_tensors=\"pt\"\n",
    "    )\n",
    "\n",
    "\n",
    "class TranscriptDataset(Dataset):\n",
    "    def __init__(self, texts, labels):\n",
    "        self.encodings = [tokenize_first_chunk(t) for t in texts]\n",
    "        self.labels = labels\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.labels)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        item = {k: v.squeeze(0) for k, v in self.encodings[idx].items()}\n",
    "        item[\"labels\"] = torch.tensor(self.labels[idx], dtype=torch.long)\n",
    "        return item\n",
    "\n",
    "\n",
    "# Train / test split\n",
    "texts  = df_labeled[\"text\"].tolist()\n",
    "label_ids = df_labeled[\"label_id\"].tolist()\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    texts, label_ids,\n",
    "    test_size=TEST_SPLIT,\n",
    "    stratify=label_ids,\n",
    "    random_state=RANDOM_SEED\n",
    ")\n",
    "\n",
    "print(f\"Train: {len(X_train)} | Test: {len(X_test)}\")\n",
    "print(\"Building datasets (this tokenizes everything — may take a minute)...\")\n",
    "\n",
    "train_dataset = TranscriptDataset(X_train, y_train)\n",
    "test_dataset  = TranscriptDataset(X_test,  y_test)\n",
    "print(\"Done.\")"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── 6. LOAD MODEL ─────────────────────────────────────────────────────────────\n",
    "model = AutoModelForSequenceClassification.from_pretrained(\n",
    "    MODEL_NAME,\n",
    "    num_labels=3,\n",
    "    id2label=ID2LABEL,\n",
    "    label2id=LABEL2ID,\n",
    "    ignore_mismatched_sizes=True   # replaces FinBERT's 3-class sentiment head\n",
    ").to(device)\n",
    "\n",
    "print(f\"Model loaded: {MODEL_NAME}\")\n",
    "print(f\"Parameters: {sum(p.numel() for p in model.parameters()):,}\")"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── 7. TRAINING ───────────────────────────────────────────────────────────────\n",
    "def compute_metrics(eval_pred):\n",
    "    logits, labels = eval_pred\n",
    "    preds = np.argmax(logits, axis=-1)\n",
    "    from sklearn.metrics import f1_score, accuracy_score\n",
    "    return {\n",
    "        \"accuracy\": accuracy_score(labels, preds),\n",
    "        \"f1_macro\": f1_score(labels, preds, average=\"macro\"),\n",
    "        \"f1_weighted\": f1_score(labels, preds, average=\"weighted\"),\n",
    "    }\n",
    "\n",
    "\n",
    "training_args = TrainingArguments(\n",
    "    output_dir              = \"./finbert-earnings\",\n",
    "    num_train_epochs        = EPOCHS,\n",
    "    per_device_train_batch_size = BATCH_SIZE,\n",
    "    per_device_eval_batch_size  = BATCH_SIZE,\n",
    "    learning_rate           = LEARNING_RATE,\n",
    "    weight_decay            = 0.01,\n",
    "    warmup_ratio            = 0.1,\n",
    "    lr_scheduler_type       = \"cosine\",\n",
    "    evaluation_strategy     = \"epoch\",\n",
    "    save_strategy           = \"epoch\",\n",
    "    load_best_model_at_end  = True,\n",
    "    metric_for_best_model   = \"f1_macro\",\n",
    "    logging_steps           = 10,\n",
    "    fp16                    = torch.cuda.is_available(),\n",
    "    report_to               = \"none\",\n",
    "    seed                    = RANDOM_SEED,\n",
    ")\n",
    "\n",
    "trainer = Trainer(\n",
    "    model           = model,\n",
    "    args            = training_args,\n",
    "    train_dataset   = train_dataset,\n",
    "    eval_dataset    = test_dataset,\n",
    "    tokenizer       = tokenizer,\n",
    "    compute_metrics = compute_metrics,\n",
    ")\n",
    "\n",
    "print(\"Starting fine-tuning...\")\n",
    "trainer.train()"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── 8. EVALUATION ─────────────────────────────────────────────────────────────\n",
    "predictions = trainer.predict(test_dataset)\n",
    "preds  = np.argmax(predictions.predictions, axis=-1)\n",
    "labels = predictions.label_ids\n",
    "\n",
    "print(\"\\n── Classification Report ──\")\n",
    "print(classification_report(\n",
    "    labels, preds,\n",
    "    target_names=[ID2LABEL[i] for i in range(3)]\n",
    "))\n",
    "\n",
    "# Confusion matrix\n",
    "cm = confusion_matrix(labels, preds)\n",
    "fig, ax = plt.subplots(figsize=(6, 5))\n",
    "sns.heatmap(\n",
    "    cm, annot=True, fmt=\"d\", cmap=\"Blues\",\n",
    "    xticklabels=list(LABEL2ID.keys()),\n",
    "    yticklabels=list(LABEL2ID.keys()),\n",
    "    ax=ax\n",
    ")\n",
    "ax.set_xlabel(\"Predicted\")\n",
    "ax.set_ylabel(\"Actual\")\n",
    "ax.set_title(\"Confusion Matrix — FinBERT Earnings Signals\")\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── 9. SAVE MODEL ─────────────────────────────────────────────────────────────\n",
    "SAVE_PATH = \"./finbert-earnings-final\"\n",
    "trainer.save_model(SAVE_PATH)\n",
    "tokenizer.save_pretrained(SAVE_PATH)\n",
    "print(f\"Model saved to {SAVE_PATH}\")\n",
    "\n",
    "# Optional: download the saved model folder as a zip\n",
    "import shutil\n",
    "shutil.make_archive(\"finbert-earnings-final\", \"zip\", SAVE_PATH)\n",
    "print(\"Zipped to finbert-earnings-final.zip — download from the Files panel on the left.\")"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── 10. INFERENCE HELPER ──────────────────────────────────────────────────────\n",
    "# Run this on any new transcript to get a Buy/Sell/Hold signal.\n",
    "# Uses chunk mean-pooling for full-document coverage.\n",
    "\n",
    "def predict_signal(transcript_text: str, model=model, tokenizer=tokenizer) -> dict:\n",
    "    \"\"\"\n",
    "    Given a raw earnings transcript string, returns:\n",
    "      { 'signal': 'Buy'|'Sell'|'Hold', 'confidence': 0-1, 'scores': {Buy, Sell, Hold} }\n",
    "    \"\"\"\n",
    "    model.eval()\n",
    "    # Split into overlapping 512-token chunks\n",
    "    tokens = tokenizer.encode(transcript_text, add_special_tokens=False)\n",
    "    chunk_size = MAX_TOKENS - 2  # reserve for [CLS] and [SEP]\n",
    "    chunks = [tokens[i:i+chunk_size] for i in range(0, len(tokens), chunk_size)]\n",
    "\n",
    "    all_logits = []\n",
    "    with torch.no_grad():\n",
    "        for chunk in chunks:\n",
    "            # Re-add special tokens\n",
    "            ids = [tokenizer.cls_token_id] + chunk + [tokenizer.sep_token_id]\n",
    "            padding = [tokenizer.pad_token_id] * (MAX_TOKENS - len(ids))\n",
    "            input_ids      = torch.tensor([ids + padding]).to(device)\n",
    "            attention_mask = torch.tensor([[1]*len(ids) + [0]*len(padding)]).to(device)\n",
    "            logits = model(input_ids=input_ids, attention_mask=attention_mask).logits\n",
    "            all_logits.append(logits.cpu())\n",
    "\n",
    "    # Mean-pool logits across chunks, then softmax\n",
    "    mean_logits = torch.stack(all_logits).mean(dim=0)\n",
    "    probs = torch.softmax(mean_logits, dim=-1).squeeze().numpy()\n",
    "\n",
    "    pred_id = int(probs.argmax())\n",
    "    return {\n",
    "        \"signal\":     ID2LABEL[pred_id],\n",
    "        \"confidence\": float(probs[pred_id]),\n",
    "        \"scores\": {\n",
    "            \"Buy\":  float(probs[LABEL2ID[\"Buy\"]]),\n",
    "            \"Hold\": float(probs[LABEL2ID[\"Hold\"]]),\n",
    "            \"Sell\": float(probs[LABEL2ID[\"Sell\"]]),\n",
    "        }\n",
    "    }\n",
    "\n",
    "\n",
    "# Quick smoke test on a test sample\n",
    "sample_text = X_test[0]\n",
    "result = predict_signal(sample_text)\n",
    "actual = ID2LABEL[y_test[0]]\n",
    "print(f\"Predicted: {result['signal']} ({result['confidence']:.1%} confidence)\")\n",
    "print(f\"Actual:    {actual}\")\n",
    "print(f\"Scores:    {result['scores']}\")"
   ],
   "execution_count": null,
   "outputs": []
  }
 ]
}"
